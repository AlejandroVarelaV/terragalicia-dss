# ------------------------------------------------------------
# TerraGalicia DSS - Environment Variables Template
# Copy this file to .env and replace placeholder values.
# Never commit real secrets.
# ------------------------------------------------------------

# Application runtime environment (dev/staging/prod)
APP_ENV=development

# Public base URL of the platform
APP_BASE_URL=https://localhost

# JWT access token signing secret
JWT_SECRET_KEY=replace-with-access-token-secret

# JWT refresh token signing secret
JWT_REFRESH_SECRET_KEY=replace-with-refresh-token-secret

# Access token duration in minutes
JWT_ACCESS_TTL_MIN=30

# Refresh token duration in days
JWT_REFRESH_TTL_DAYS=7

# SQLAlchemy/driver URL for PostGIS application database
DATABASE_URL_POSTGIS=postgresql://terragalicia:terragalicia@postgres:5432/terragalicia

# SQLAlchemy/driver URL for TimescaleDB time-series database
DATABASE_URL_TIMESCALE=postgresql://timescale:timescale@timescaledb:5432/terragalicia_ts

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# Orion Context Broker base URL
ORION_BASE_URL=http://orion:1026

# FIWARE service header used by Orion/IoT Agent
ORION_SERVICE=terragalicia

# FIWARE service path header used by Orion/IoT Agent
ORION_SERVICEPATH=/

# Comma-separated NGSI-LD context URLs
NGSI_LD_CONTEXT_URLS=https://uri.fiware.org/ns/data-models,https://schema.org

# IoT Agent northbound base URL
IOTA_NORTH_URL=http://iot-agent:4041

# IoT Agent southbound HTTP port
IOTA_SOUTH_HTTP_PORT=7896

# MQTT broker host
MQTT_BROKER_HOST=mqtt-broker

# MQTT broker port
MQTT_BROKER_PORT=1883

# MQTT username (if broker auth enabled)
MQTT_USERNAME=terragalicia

# MQTT password (if broker auth enabled)
MQTT_PASSWORD=change-me

# QuantumLeap base URL
QUANTUMLEAP_BASE_URL=http://quantumleap:8668

# AEMET API key (external dependency)
AEMET_API_KEY=replace-with-aemet-key

# MeteoGalicia API key (external dependency)
METEOGALICIA_API_KEY=replace-with-meteogalicia-key

# SIGPAC source endpoint (external dependency)
SIGPAC_SOURCE_URL=https://example.sigpac.endpoint

# Copernicus source endpoint (external dependency)
COPERNICUS_SOURCE_URL=https://example.copernicus.endpoint

# CSIC soil map source endpoint (external dependency)
CSIC_SOIL_SOURCE_URL=https://example.csic.endpoint

# IGN MDT05 DEM source endpoint (external dependency)
IGN_MDT05_SOURCE_URL=https://example.ign.endpoint

# ML service base URL
ML_SERVICE_URL=http://ml-service:8010

# Version/tag of the active ML model
ML_MODEL_VERSION=v1

# LLM provider selector (ollama/openai/custom)
LLM_PROVIDER=ollama

# LLM API base URL
LLM_API_BASE=http://llm-service:11434

# LLM API key/token (external dependency if remote provider)
LLM_API_KEY=replace-with-llm-key

# Grafana admin username
GRAFANA_ADMIN_USER=admin

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=change-me

# TLS certificate path used by Nginx
TLS_CERT_PATH=/etc/nginx/certs/dev.crt

# TLS private key path used by Nginx
TLS_KEY_PATH=/etc/nginx/certs/dev.key

# -------------------------
# Compose runtime variables
# -------------------------

# PostgreSQL/PostGIS container credentials and database
POSTGRES_USER=terragalicia
POSTGRES_PASSWORD=change-me
POSTGRES_DB=terragalicia

# TimescaleDB container credentials and database
TIMESCALEDB_USER=timescale
TIMESCALEDB_PASSWORD=change-me
TIMESCALEDB_DB=terragalicia_ts

# MongoDB root credentials for Orion/IoT Agent metadata store
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
